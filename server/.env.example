# ============================================
# Database Configuration (REQUIRED)
# ============================================
# Option A — Named instance (Browser service must be running):
#   DB_SERVER=.\SQLEXPRESS  DB_PORT=  DB_INSTANCE_NAME=
# Option B — Static TCP port (recommended for local dev, no Browser needed):
#   DB_SERVER=localhost  DB_PORT=1434  DB_INSTANCE_NAME=
DB_SERVER=localhost
DB_PORT=1434
DB_INSTANCE_NAME=
DB_NAME=MTB_FAC_OPS_WEB
DB_USER=sa
DB_PASSWORD=YourStrongPassword

# ============================================
# JWT Configuration (REQUIRED)
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================
# App Configuration (OPTIONAL)
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# Authentication Configuration (OPTIONAL)
# ============================================
# Dev Bypass: allow ?dev_employee_id query param in development
# WARNING: ONLY enable in development. Must be 'false' in production
AUTH_DEV_BYPASS=true

# ============================================
# OIDC Configuration (OPTIONAL - for future)
# ============================================
# When ready to use OIDC, provide these values
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_AUDIENCE=
OIDC_DISCOVERY_URL=
