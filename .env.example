# =====================================================
# 資料庫連線設定
# =====================================================
# 實際架構:
#   A 廠 RDS02 (source) ────┐
#                            ▼
#                         DBA02 (主操作 DB, Web 查這裡)
#                            ▲
#   B 廠 B1SA01 (source) → DBA03 (中繼) ──┘
#
# 本機模擬對應:
#   FAC_RDS02_Sim  ←→ A 廠 source
#   FAC_B1SA01_Sim ←→ B 廠 source
#   FAC_DBA03_Sim  ←→ B 廠中繼
#   FAC_DBA02      ←→ 主操作 DB
# =====================================================

# ----- DBA02: 主操作 DB（讀寫，Web 連這個） -----
DB_DBA02_HOST=localhost
DB_DBA02_PORT=1433
DB_DBA02_DATABASE=FAC_DBA02
DB_DBA02_USER=sa
DB_DBA02_PASSWORD=your_password_here

# ----- RDS02: A 廠 source DB（唯讀） -----
DB_RDS02_HOST=localhost
DB_RDS02_PORT=1433
DB_RDS02_DATABASE=FAC_RDS02_Sim
DB_RDS02_USER=sa
DB_RDS02_PASSWORD=your_password_here

# ----- B1SA01: B 廠 source DB（唯讀，實際部署時在內網） -----
DB_B1SA01_HOST=localhost
DB_B1SA01_PORT=1433
DB_B1SA01_DATABASE=FAC_B1SA01_Sim
DB_B1SA01_USER=sa
DB_B1SA01_PASSWORD=your_password_here

# ----- DBA03: B 廠中繼 DB（外網，VM 可連） -----
DB_DBA03_HOST=localhost
DB_DBA03_PORT=1433
DB_DBA03_DATABASE=FAC_DBA03_Sim
DB_DBA03_USER=sa
DB_DBA03_PASSWORD=your_password_here

# =====================================================
# JWT
# =====================================================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=8h

# =====================================================
# Server
# =====================================================
PORT=3000
NODE_ENV=development

# =====================================================
# Sync 排程設定（獨立同步程式使用）
# =====================================================
# A 廠 Alarm 同步間隔（秒）
SYNC_ALARM_A_INTERVAL_SEC=300
# B 廠 Alarm 同步間隔（秒）
SYNC_ALARM_B_INTERVAL_SEC=300
